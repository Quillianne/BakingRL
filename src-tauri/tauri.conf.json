{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BakingRL",
  "version": "0.1.0",
  "identifier": "com.quillianne.bakingrl",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "BakingRL Configuration",
        "label": "main",
        "url": "/",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "decorations": false
      },
      {
        "title": "BakingRL Overlay",
        "label": "overlay-ingame",
        "url": "/overlay/ingame",
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../build": "build"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["bakingrl"]
      }
    }
  }
}
