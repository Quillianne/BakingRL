{
  "name": "bakingrl",
  "version": "0.10.2",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "npm run extension-host:build && vite dev",
    "build": "npm run extension-host:build && svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "docs:build": "quarkdown c docs-src/main.qd -o docs-site --clean --subdoc-naming file-name",
    "docs:dev": "quarkdown c docs-src/main.qd -o docs-site --clean --subdoc-naming file-name -p -w",
    "extension-host:build": "esbuild src-tauri/extension-host/bootstrap.ts --bundle --platform=node --format=esm --target=node20 --outfile=src-tauri/gen/extension-host/bootstrap.mjs",
    "extension-host:smoke": "node scripts/smoke-extension-host.mjs",
    "node:prepare": "node scripts/prepare-node-sidecar.mjs",
    "tauri:before-build": "npm run node:prepare && npm run build",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.12",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
